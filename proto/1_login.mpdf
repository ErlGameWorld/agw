%% ----------------------------------------
%% 握手协议 (建立连接后必须先发)
%% ----------------------------------------
cs_handshake {
    int32 encrypt1;
    int32 encrypt2;
}

sc_handshake {
    int32 result; %% 0:success, >0:error
}

%% ----------------------------------------
%% 心跳协议 (客户端定时发送，建议间隔10秒)
%% ----------------------------------------
cs_heartbeat {
}

sc_heartbeat {
}

%% ----------------------------------------
%% 登录
%% ----------------------------------------
cs_login {
    string name;
}

sc_login {
    int32 result; %% 0:success, >0:error
    string playerId;
    playerInfo player;
}
