%% ========================================
%% 房间模块
%% ========================================

%% ----------------------------------------
%% 房间列表
%% ----------------------------------------
cs_list_rooms {
}

sc_list_rooms {
    list[roomInfo] rooms;
}

%% ----------------------------------------
%% 创建房间
%% ----------------------------------------
cs_create_room {
    string name;
}

sc_room_update {
    string roomId;
    int32 status; %% 0:joined, 1:left, 2:created
    list[playerInfo] players;
}

%% ----------------------------------------
%% 加入房间
%% ----------------------------------------
cs_join_room {
    string roomId;
}

%% 加入房间也返回 sc_room_update

%% ----------------------------------------
%% 离开房间
%% ----------------------------------------
cs_leave_room {
    string roomId;
}

%% 离开房间也返回 sc_room_update

%% ----------------------------------------
%% 快速匹配
%% ----------------------------------------
cs_quick_match {
}

%% 快速匹配也返回 sc_room_update

%% ----------------------------------------
%% 添加AI玩家
%% ----------------------------------------
cs_add_ai {
}

sc_ai_added {
    string name;
    int32 index;
}

%% ----------------------------------------
%% 开始游戏
%% ----------------------------------------
cs_game_start {
}

sc_game_start {
    list[card] cards;
    int32 firstBidder; %% 1, 2, 3
}

%% ----------------------------------------
%% 叫分
%% ----------------------------------------
cs_bid {
    int32 score; %% 0, 1, 2, 3
}

sc_bid_made {
    int32 playerIdx;
    int32 score;
}

sc_turn_to_bid {
    int32 nextTurn; %% 1, 2, 3
    list[int32] currentBids;
}

%% ----------------------------------------
%% 出牌
%% ----------------------------------------
cs_play {
    list[card] cards;
}

sc_player_played {
    int32 playerIdx;
    list[card] cards;
}

%% ----------------------------------------
%% 不出
%% ----------------------------------------
cs_pass {
}

sc_player_passed {
    int32 playerIdx;
}

%% ----------------------------------------
%% 出牌提示
%% ----------------------------------------
cs_play_hint {
}

sc_play_hint {
    list[card] cards;
}

%% ----------------------------------------
%% 轮到出牌 (服务端推送)
%% ----------------------------------------
sc_turn_to_play {
    int32 nextTurn;
    list[card] lastPlay;
}

%% ----------------------------------------
%% 地主确定 (服务端推送)
%% ----------------------------------------
sc_landlord_selected {
    int32 landlordIdx;
    list[card] landlordCards;
    int32 baseScore;
}

%% ----------------------------------------
%% 游戏结束 (服务端推送)
%% ----------------------------------------
sc_game_over {
    int32 winnerIdx;
    list[scoreInfo] scores;
}

%% ----------------------------------------
%% 准备/取消准备
%% ----------------------------------------
cs_ready {
    int32 ready; %% 0:取消准备, 1:准备
}

sc_player_ready {
    int32 playerIdx;
    int32 ready;    %% 0:取消准备, 1:准备
    int32 allReady; %% 0:未全员准备, 1:全员准备
}
